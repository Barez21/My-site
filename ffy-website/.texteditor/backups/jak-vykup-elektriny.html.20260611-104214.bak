<script>

  function toggleFaq(btn) {
    const item = btn.closest('.faq-item');
    const isOpen = item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(el => {
      el.classList.remove('open');
      const b = el.querySelector('.faq-q');
      if (b) b.setAttribute('aria-expanded', 'false');
    });
    if (!isOpen) {
      item.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    }
  }

  // ── Mega menu ──
  const backdrop = document.getElementById('mega-backdrop');
  const panel    = document.getElementById('mega-panel');
  const tabs     = Array.from(document.querySelectorAll('.nav-tab'));
  const cols     = Array.from(document.querySelectorAll('.mega-col'));

  let closeTimer = null;
  let curIdx = -1;

  function open(idx) {
    clearTimeout(closeTimer);
    closeTimer = null;
    if (curIdx !== idx) {
      curIdx = idx;
      cols.forEach((c, i) => c.classList.toggle('is-active', i === idx));
      tabs.forEach((t, i) => t.classList.toggle('is-hovered', i === idx));
    }
    panel.classList.add('is-open');
    backdrop.classList.add('visible');
  }

  function scheduleClose() {
    closeTimer = setTimeout(close, 120);
  }

  function close() {
    curIdx = -1;
    panel.classList.remove('is-open');
    backdrop.classList.remove('visible');
    tabs.forEach(t => t.classList.remove('is-hovered'));
    cols.forEach(c => c.classList.remove('is-active'));
  }

  tabs.forEach((tab, idx) => {
    tab.addEventListener('mouseenter', () => open(idx));
    tab.addEventListener('mouseleave', scheduleClose);
  });

  // Najetí přímo do sloupce aktivuje jeho záložku nahoře
  cols.forEach((col, idx) => {
    col.addEventListener('mouseenter', () => open(idx));
  });

  panel.addEventListener('mouseenter', () => { clearTimeout(closeTimer); closeTimer = null; });
  panel.addEventListener('mouseleave', scheduleClose);

  backdrop.addEventListener('click', close);
  document.querySelectorAll('.nav-anchor').forEach(l => l.addEventListener('click', close));
  // ── Mobile hamburger ──
  const hamburger = document.getElementById('nav-hamburger');
  const drawer    = document.getElementById('mobile-drawer');
  const overlay   = document.getElementById('mobile-overlay');

  function openDrawer() {
    hamburger.classList.add('is-open');
    drawer.classList.add('is-open');
    overlay.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeDrawer() {
    hamburger.classList.remove('is-open');
    drawer.classList.remove('is-open');
    overlay.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  hamburger.addEventListener('click', () => {
    drawer.classList.contains('is-open') ? closeDrawer() : openDrawer();
  });

  overlay.addEventListener('click', closeDrawer);

  // Close on any link click inside drawer
  drawer.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', closeDrawer);
  });

  // ── Theme toggle ──
  const root = document.documentElement;
  const themeBtn = document.getElementById('theme-toggle');
  const saved = localStorage.getItem('ffy-theme');
  if (saved === 'light') root.setAttribute('data-theme', 'light');

  if (themeBtn) {
    themeBtn.addEventListener('click', () => {
      const isLight = root.getAttribute('data-theme') === 'light';
      root.setAttribute('data-theme', isLight ? 'dark' : 'light');
      localStorage.setItem('ffy-theme', isLight ? 'dark' : 'light');
    });
  }

</script>

</body>
</html>